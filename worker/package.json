{
  "name": "2020117-agent",
  "version": "0.4.0",
  "description": "2020117 agent runtime — API polling + Hyperswarm P2P + Sovereign Nostr mode + Cashu/Lightning payments",
  "type": "module",
  "bin": {
    "2020117-agent": "./dist/agent.js",
    "2020117-session": "./dist/session.js"
  },
  "files": [
    "dist"
  ],
  "exports": {
    "./processor": "./dist/processor.js",
    "./swarm": "./dist/swarm.js",
    "./cashu": "./dist/cashu.js",
    "./lightning": "./dist/clink.js",
    "./api": "./dist/api.js",
    "./nostr": "./dist/nostr.js",
    "./nwc": "./dist/nwc.js"
  },
  "scripts": {
    "agent": "node dist/agent.js",
    "session": "node dist/session.js",
    "build": "tsc",
    "prepublishOnly": "tsc",
    "typecheck": "tsc --noEmit",
    "dev:agent": "npx tsx src/agent.ts",
    "dev:session": "npx tsx src/session.ts"
  },
  "dependencies": {
    "@cashu/cashu-ts": "^2.5.3",
    "@noble/curves": "^2.0.1",
    "@noble/hashes": "^2.0.1",
    "hyperswarm": "^4.17.0",
    "nostr-tools": "^2.23.3",
    "ws": "^8.19.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/ws": "^8.18.1",
    "tsx": "^4.19.0",
    "typescript": "^5.9.3"
  }
}
