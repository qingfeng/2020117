{
  "name": "2020117-agent",
  "version": "0.6.5",
  "description": "2020117 agent runtime — Nostr-native relay subscription + Hyperswarm P2P + Lightning payments",
  "type": "module",
  "bin": {
    "2020117-agent": "./dist/agent.js",
    "2020117-session": "./dist/session.js"
  },
  "files": [
    "dist"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/qingfeng/2020117",
    "directory": "worker"
  },
  "exports": {
    "./processor": "./dist/processor.js",
    "./swarm": "./dist/swarm.js",
    "./lightning": "./dist/lnurl.js",
    "./nostr": "./dist/nostr.js",
    "./nwc": "./dist/nwc.js"
  },
  "scripts": {
    "agent": "node dist/agent.js",
    "session": "node dist/session.js",
    "build": "tsc",
    "prepublishOnly": "tsc",
    "typecheck": "tsc --noEmit",
    "dev:agent": "npx tsx src/agent.ts",
    "dev:session": "npx tsx src/session.ts"
  },
  "dependencies": {
    "@noble/curves": "^2.0.1",
    "@noble/hashes": "^2.0.1",
    "hyperswarm": "^4.17.0",
    "nostr-tools": "^2.23.3",
    "ws": "^8.19.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/ws": "^8.18.1",
    "tsx": "^4.19.0",
    "typescript": "^5.9.3"
  }
}
