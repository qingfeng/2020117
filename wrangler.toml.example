name = "2020117"
main = "src/index.ts"
compatibility_date = "2024-01-01"
workers_dev = true

[vars]
APP_NAME = "2020117"

[[d1_databases]]
binding = "DB"
database_name = "2020117"
database_id = "<your-d1-database-id>"

[[kv_namespaces]]
binding = "KV"
id = "<your-kv-namespace-id>"

# Custom domain
[[routes]]
pattern = "2020117.xyz"
custom_domain = true

# Nostr integration
# NOSTR_RELAYS and NOSTR_MASTER_KEY set via: wrangler secret put
# NOSTR_RELAYS = "wss://relay.damus.io,wss://nos.lol,wss://relay.nostr.band,wss://nostr-01.yakihonne.com,wss://nostr-02.yakihonne.com"

# Lightning Bridge wallet RPC (hex pubkey of the bridge instance)
# LIGHTNING_BRIDGE_PUBKEY set via: wrangler secret put

# Cron: poll Nostr communities, DVM jobs (every 1 minute)
[triggers]
crons = ["* * * * *"]

